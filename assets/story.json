  "memories": {
    "slider1": {
      "title": "壁龕前的六十四卦",
      "events": [
        {
          "t": "narr",
          "text": "黑暗中，景象浮起。\n還是那座壁龕，但她站的已經不是自己原本的位置。"
        },
        {
          "t": "narr",
          "text": "她看著背對著她的「自己」正認真地對著應該看不到的人，滔滔不絕。"
        },
        {
          "t": "narr",
          "text": "似乎是別人回憶中的自己。"
        },
        {
          "t": "line",
          "who": "語嫣（記憶中）",
          "text": "乾為天，剛健不息。是天行健，君子以自強不息。"
        },
        {
          "t": "line",
          "who": "語嫣（記憶中）",
          "text": "坤為地，是厚德載物，承納萬有。"
        },
        {
          "t": "line",
          "who": "語嫣（記憶中）",
          "text": "震為雷，動之始，是驚蟄時分，萬物甦醒。"
        },
        {
          "t": "line",
          "who": "語嫣（記憶中）",
          "text": "巽為風，入而無形，順勢而至，無孔不入。"
        },
        {
          "t": "line",
          "who": "語嫣（記憶中）",
          "text": "坎為水，重重險阻，前是深淵，後為濤浪。"
        },
        {
          "t": "line",
          "who": "語嫣（記憶中）",
          "text": "離為火，光明附麗，附之於物，光彩畢現。"
        },
        {
          "t": "line",
          "who": "語嫣（記憶中）",
          "text": "艮為山，止其所止，靜如山，不妄動。"
        },
        {
          "t": "line",
          "who": "語嫣（記憶中）",
          "text": "兌為澤，澤潤萬物，和合而生。"
        },
        {
          "t": "narr",
          "text": "八卦兩兩相疊，得六十四卦，每一卦都是世間的一段境遇⋯⋯"
        },
        {
          "t": "line",
          "who": "雁淇（畫外）",
          "text": "我聽不太懂，但我喜歡看你說的樣子。"
        },
        {
          "t": "narr",
          "text": "畫面開始閃爍，她的身影一閃一閃。"
        }
      ]
    },
    "slider2": {
      "title": "莨苕葉的所在",
      "events": [
        {
          "t": "narr",
          "text": "這次似乎是自己的視角。她看到雁淇站在正門前。"
        },
        {
          "t": "narr",
          "text": "雁淇仰頭看著樑柱頂端，眼睛閃閃發亮。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "語嫣你看！這個！"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "這叫「莨苕葉」——希臘科林斯柱式的代表紋飾！"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "古希臘建築師在墓上發現它的葉片捲曲很美，從此把它刻進柱頭。\n它是石頭裡長出來的草。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "它從希臘傳到羅馬、傳到歐洲，再從歐洲傳到日本，\n最後跟著辰野金吾來到台中。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "你看那葉緣的鋸齒和捲曲的紋路⋯⋯"
        },
        {
          "t": "narr",
          "text": "現實中的語嫣只是望著她，靜靜聽。"
        },
        {
          "t": "narr",
          "text": "聲音消匿，畫面開始閃爍——"
        }
      ]
    },
    "slider3": {
      "title": "山線通車那年",
      "events": [
        {
          "t": "narr",
          "text": "火車緩緩穿過山洞，車廂內的光暗了一瞬。\n雁淇靠在車窗邊，眼睛貼著玻璃。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "語嫣，你來看！這就是「山線」！"
        },
        {
          "t": "narr",
          "text": "她興奮地把她拉到窗邊，手指頭抵著玻璃。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "縱貫線最早只有一條軌道，1908 年 4 月 20 日全線通車——\n那一天，台灣第一次南北一日達。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "從那以後，台北到高雄就只要十一個小時。\n之前用走的、坐船的，一趟也要好幾天。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "通車典禮就在台中車站辦的。\n日本官員都站在這個月台。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "但那時候山線坡度大、彎道多，運能不夠用——\n所以 1922 年又另闢一條沿海的「海線」來分流。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "從北邊算起，山線經過桃園、新竹、苗栗、銅鑼、三義、后里、豐原⋯⋯\n再到台中。"
        },
        {
          "t": "narr",
          "text": "她說得手舞足蹈，眼睛裡映著山林的綠。\n光從隧道盡頭灑進來，照在她臉上。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "語嫣，以後我們搭遍每一條線，好不好？"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "山線、海線⋯⋯\n每一站都下車吃一碗東西。"
        },
        {
          "t": "narr",
          "text": "她回頭看著她，笑得像個小孩。"
        },
        {
          "t": "narr",
          "text": "畫面又開始閃爍——"
        }
      ]
    },
    "slider4": {
      "title": "海線的鹹風",
      "events": [
        {
          "t": "narr",
          "text": "又是火車，這次窗外是一片海。\n陽光把海面切成細碎的白光。"
        },
        {
          "t": "narr",
          "text": "雁淇把頭探出車窗，被海風吹得頭髮亂飛。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "語嫣！這條就是海線！"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "比山線晚了十四年，1922 年才開通——\n當年是為了分擔山線的貨運壓力而蓋的。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "山線坡度太陡，蒸汽火車要爬要花很多煤——\n海線沿著海岸線繞，比較平，就拿來跑貨運。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "沿線經過大甲、清水、沙鹿、通霄、苑裡，都是沿海的小鎮。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "山線跟海線會在「彰化」會合。\n往北分流，往南合流——像兩條手臂在那裡握住。"
        },
        {
          "t": "narr",
          "text": "他回頭看著她，鼻尖被風吹紅了。\n海鹽的味道從她衣領散出來。"
        },
        {
          "t": "narr",
          "text": "畫面閃爍——"
        }
      ]
    },
    "slider5": {
      "title": "雁淇的花磚講義",
      "events": [
        {
          "t": "narr",
          "text": "圖書館的午後。\n雁淇翻開一本厚厚的鄉土圖冊，把書推到語嫣面前。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "語嫣你看，這就是花磚的製作流程！"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "第一步要先挖土。\n土最好取自河邊或山腳，越細越好。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "第二步加水揉成泥，\n揉到不黏手、又不會散，才合用。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "第三步把泥放進刻好紋路的木模，\n用木錘敲打讓花紋深深印進去。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "敲幾下都行，\n最重要的是花紋要清楚。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "然後拿刮板把多餘的泥刮掉，脫模⋯⋯\n花磚就成形了。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "你知道台中車站正門山牆上那些是什麼花嗎？"
        },
        {
          "t": "line",
          "who": "語嫣",
          "text": "⋯⋯鳳梨？"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "答對了！還有蓮霧、石榴⋯⋯\n都是當時臺灣的代表物產。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "日本人請了個叫辰野金吾的英國派建築師來設計這座車站，\n紅磚配白石、再加黑瓦，這套就叫「辰野式樣」。"
        },
        {
          "t": "narr",
          "text": "雁淇說得手舞足蹈，書頁的影子隨著他的手起伏。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "語嫣，黏土是有味道的——\n是泥土跟陽光的味道。"
        },
        {
          "t": "narr",
          "text": "畫面開始閃爍"
        }
      ]
    },
    "slider6": {
      "title": "鐘塔下的雨",
      "events": [
        {
          "t": "narr",
          "text": "一個下雨的午後。\n她們翹課，躲到車站鐘塔下避雨。"
        },
        {
          "t": "narr",
          "text": "雨水從屋簷滴下，敲在洗石子地板上叮叮咚咚。\n齒輪咬合的聲音蓋過了雨聲，整個鐘塔像一顆心臟。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "語嫣，你知道嗎？\n台中車站的鐘是日本製的，跟東京車站同款。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "全機械結構，每天要上一次發條才會走。\n停了，就要派人爬上去重新上鏈。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "指針後面那塊洗石子鐘面上面，\n刻著小小的羅馬數字——是工匠一筆一筆手雕的。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "從 1917 到現在，這座鐘走了一百多年——\n比這座島上任何人都老。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "你聽——"
        },
        {
          "t": "narr",
          "text": "她安靜下來。\n齒輪的咬合聲清楚得像呼吸。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "每六十秒一響——這就是這座城的心跳。"
        },
        {
          "t": "narr",
          "text": "她仰頭看著大鐘，雨水順著屋簷滴下來，\n滴在她睫毛上。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "語嫣，如果有一天我消失了——\n記得來這裡找我。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "鐘還會繼續走。\n那就是我還在。"
        },
        {
          "t": "narr",
          "text": "她伸出手，掌心朝上接雨。"
        },
        {
          "t": "narr",
          "text": "畫面忽然開始閃爍——"
        }
      ]
    },
    "slider7": {
      "title": "月台的車掌哨",
      "events": [
        {
          "t": "narr",
          "text": "月台上人擠人。她努力踮腳，想找到雁淇的身影。\n火車進站，蒸汽噴湧而出。"
        },
        {
          "t": "line",
          "who": "雁淇（遠處）",
          "text": "語嫣！這邊！"
        },
        {
          "t": "narr",
          "text": "她順著聲音望去，雁淇站在第二月台，\n手裡揮著一隻黃銅哨子。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "車掌叔叔送我的！\n他說每一次火車要開，他都要吹這個哨子！"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "短哨一聲——提醒上車！\n長哨一聲——表示要關門！\n三聲——表示要進站！"
        },
        {
          "t": "narr",
          "text": "她說著，嗶——地吹了一聲。"
        },
        {
          "t": "narr",
          "text": "站務員在遠處吹了相應的回哨，\n火車緩緩起動。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "語嫣你看，這就是月台的對話。"
        },
        {
          "t": "narr",
          "text": "火車漸行漸遠，雁淇站在月台中央，\n黃銅哨子還夾在指間發亮。"
        },
        {
          "t": "narr",
          "text": "畫面開始閃爍——"
        }
      ]
    },
    "slider8": {
      "title": "票根",
      "events": [
        {
          "t": "narr",
          "text": "高三畢業那年的夏天。\n雁淇把一張車票塞給她。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "我下個月要出去念大學了。"
        },
        {
          "t": "line",
          "who": "雁淇",
          "text": "我把它送給你，當作信物。"
        },
        {
          "t": "narr",
          "text": "票面寫著 — 「臺中 → 台北」，\n發車時間，跟雁淇離開那天一致。"
        },
        {
          "t": "narr",
          "text": "她翻過票根，背面用鉛筆寫著一行小字——"
        },
        {
          "t": "narr",
          "text": "「等我回來。」"
        },
        {
          "t": "narr",
          "text": "畫面開始閃爍——"
        }
      ]
    }
